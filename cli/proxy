#!/bin/bash

INSTALL_DIR="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || realpath "$0" 2>/dev/null || echo "$0")")" && pwd)"

case "${1}" in
    start)
        flag="${2}"
        [ "${flag}" = "-a" ] && flag="--always"
        # ${3} is an optional watchdog interval in seconds (e.g. `proxy start -a 10`)
        bash "${INSTALL_DIR}/start.sh" "${flag}" "${3}"
        ;;
    stop)
        bash "${INSTALL_DIR}/stop.sh"
        ;;
    status)
        source "${INSTALL_DIR}/.env"
        if curl -s --max-time 3 -x http://127.0.0.1:${HTTP_PROXY_PORT} \
            https://api.ipify.org 2>/dev/null | grep -qE "[0-9]+\.[0-9]+"; then
            echo "Proxy is running (exit IP: $(curl -s --max-time 3 -x http://127.0.0.1:${HTTP_PROXY_PORT} https://api.ipify.org 2>/dev/null))"
        else
            echo "Proxy is not running"
        fi
        ;;
    socks-on|so)
        source "${INSTALL_DIR}/.env"
        git config --global http.proxy socks5h://127.0.0.1:${SOCKS_PORT}
        git config --global https.proxy socks5h://127.0.0.1:${SOCKS_PORT}
        echo "Git proxy configured (socks5h://127.0.0.1:${SOCKS_PORT})"
        if [ "$(uname -s)" = "Darwin" ]; then
            sudo networksetup -setsocksfirewallproxy "${NETWORK_SERVICE}" 127.0.0.1 "${SOCKS_PORT}"
            sudo networksetup -setsocksfirewallproxystate "${NETWORK_SERVICE}" on
            echo "macOS SOCKS proxy enabled on ${NETWORK_SERVICE} (127.0.0.1:${SOCKS_PORT})"
        fi
        ;;
    socks-off|sf)
        source "${INSTALL_DIR}/.env"
        git config --global --unset http.proxy 2>/dev/null
        git config --global --unset https.proxy 2>/dev/null
        echo "Git proxy configuration removed"
        if [ "$(uname -s)" = "Darwin" ]; then
            sudo networksetup -setsocksfirewallproxystate "${NETWORK_SERVICE}" off
            echo "macOS SOCKS proxy disabled on ${NETWORK_SERVICE}"
        fi
        ;;
    log|logs)
        source "${INSTALL_DIR}/.env"
        tail -f "${LOG_FILE}"
        ;;
    *)
        echo "Usage: proxy {start [--always|-a [interval_seconds]]|stop|status|socks-on(so)|socks-off(sf)|log}"
        exit 1
        ;;
esac
